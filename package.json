{
  "name": "react-query-ssr",
  "version": "1.0.3",
  "main": "./dist/cjs/index.js",
  "types": "./dist/cjs/index.d.ts",
  "exports": {
    "require": "./dist/cjs/index.js",
    "import": "./dist/esm/index.js"
  },
  "description": "Library for easy SSR of data obtained from asynchronous in Next.js.",
  "license": "MIT",
  "scripts": {
    "build": "tsc && tsc --project ./tsconfig.esm.json && cpy esm dist",
    "lint": "eslint --fix ./src",
    "lint:fix": "eslint --fix ./src"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@tanstack/react-query": "^5.100.14",
    "@types/react": "19.2.15",
    "cpy-cli": "^7.0.0",
    "eslint": "10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "prettier": "^3.8.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4"
  },
  "keywords": [
    "nextjs",
    "react",
    "react-query",
    "ssr",
    "fetch"
  ],
  "author": "SoraKumo <info@croud.jp>",
  "repository": "https://github.com/ReactLibraries/react-query-ssr"
}
